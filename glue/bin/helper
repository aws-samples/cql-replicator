#!/usr/bin/env bash
#
# // Copyright Amazon.com, Inc. or its affiliates. All Rights Reserved.
# // SPDX-License-Identifier: Apache-2.0
#
# The following script supports only bash versions 4 and 5
# Recovery parameters
declare -A params=(
    [MIGRATOR_VERSION]="1.0"
    [DESCRIPTION]="CQLReplicator Helper"
    [TILES]=8
    [S3_LANDING_ZONE]=""
    [SOURCE_KS]=""
    [SOURCE_TBL]=""
)

# Define color codes
LIGHT_GREEN='\033[1;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() { echo -e "${LIGHT_GREEN}INFO [$(date -Iseconds)]${NC} $*"; }
log_error() { echo -e "${RED}ERROR [$(date -Iseconds)]${NC} $*"; }
log_warn() { echo -e "${YELLOW}WARN [$(date -Iseconds)]${NC} $*"; }

Usage_Exit() {
    echo "Usage: $0 [options]"
    echo "Options:"
    echo "  --state STATE             Set the state"
    echo "  --tiles, -t TILES         Set the number of tiles"
    echo "  --landing-zone, -lz ZONE  Set the S3 landing zone"
    echo "  --src-keyspace, -sk KS    Set the source keyspace"
    echo "  --src-table, -st TABLE    Set the source table"
    echo "  --region, -sr REGION      Set the AWS region"
    exit 1
}

get_region_code() {
    local region="$1"

    case "${region,,}" in
        us-east-1)     echo "USE1" ;;
        us-east-2)     echo "USE2" ;;
        us-west-1)     echo "USW1" ;;
        us-west-2)     echo "USW2" ;;
        eu-west-1)     echo "EUW1" ;;
        eu-central-1)  echo "EUC1" ;;
        ap-southeast-1) echo "APS1" ;;
        ap-southeast-2) echo "APS2" ;;
        ap-northeast-1) echo "APN1" ;;
        af-south-1) echo "AFS1" ;;
        *)
            log_warn "TCO Unknown region format" >&2
            return 0
            ;;
    esac
}

Get_TCO() {
  # Execute the AWS CLI command to fetch Glue DPU price
  local price
  local region_code=$(get_region_code "${params[AWS_REGION]}")
  price=$(aws pricing get-products \
    --service-code AWSGlue \
    --filters "Type=TERM_MATCH,Field=usagetype,Value=${region_code}-ETL-DPU-Hour" 2>/dev/null  \
    | jq -r '.PriceList[] | fromjson | .terms.OnDemand[].priceDimensions[].pricePerUnit.USD' 2>/dev/null)
  # Check if the command was successful and a price was returned
  if [[ $? -eq 0 && -n "$price" && "$price" != "null" ]]; then
    # Format the price in U.S. dollars
    total_tco=$(echo "scale=2; ($price * ${params[TOTAL_DPU]} + 0.005) / 1" | bc -l)
    log_info "The price of a Glue DPU is $price USD per hour. ${RED}The total cost of running CQLReplicator is $total_tco USD per hour${NC}"
  else
    # Print an error message if the price could not be retrieved
    log_warn "Unable to retrieve the Glue TCO"
  fi
}

function Recovery {
    log_info "Iceberg recovery validation started for ${params[SOURCE_KS]}.${params[SOURCE_TBL]} with ${params[TILES]} tiles"
    local issues_found=0
    local tiles_missing_metadata=0
    local db_name="${params[SOURCE_KS]}_db"
    local base_iceberg_path="${params[S3_LANDING_ZONE]}/${params[SOURCE_KS]}/${params[SOURCE_TBL]}/iceberg"

    # Step 1: Verify per-tile Iceberg tables exist in the Glue Data Catalog
    for tile in $(seq 0 $(( ${params[TILES]} - 1 ))); do
      local tbl_name="${params[SOURCE_TBL]}_tile_${tile}_pk_snapshots"
      log_info "Verifying Iceberg table: ${db_name}.${tbl_name}"
      local get_table_output
      get_table_output=$(aws glue get-table --database-name "$db_name" --name "$tbl_name" --region "${params[AWS_REGION]}" 2>&1)
      local get_table_rc=$?

      if [[ $get_table_rc -ne 0 ]]; then
          log_info "Iceberg table '${db_name}.${tbl_name}' not found in Glue Data Catalog (will be created by Discovery)"
          ((tiles_missing_metadata++))
      else
          log_info "Iceberg table '${db_name}.${tbl_name}' exists"
      fi

      # Step 2: Validate Iceberg metadata files exist in S3 for this tile
      local iceberg_path="${base_iceberg_path}/tile_${tile}/"
      local metadata_listing
      metadata_listing=$(aws s3 ls "${iceberg_path}metadata/" 2>&1)
      local metadata_rc=$?

      if [[ $metadata_rc -ne 0 || -z "$metadata_listing" ]]; then
          log_info "No Iceberg metadata found at ${iceberg_path}metadata/ for tile $tile"
          ((tiles_missing_metadata++))
      else
          local metadata_json_count
          metadata_json_count=$(echo "$metadata_listing" | grep -c '\.metadata\.json' || true)
          if [[ $metadata_json_count -eq 0 ]]; then
              log_info "No metadata JSON files found at ${iceberg_path}metadata/ for tile $tile"
              ((tiles_missing_metadata++))
          else
              log_info "Tile $tile: $metadata_json_count metadata JSON file(s)"
          fi
      fi
    done

    # Step 3: Summary
    # If ALL tiles are missing metadata, this is a first load — not an error
    local total_checks=$(( ${params[TILES]} * 2 ))
    if [[ $tiles_missing_metadata -eq $total_checks ]]; then
        log_info "No existing Iceberg data found for any tile. This is a first load — Discovery will create everything."
    elif [[ $tiles_missing_metadata -eq 0 ]]; then
        log_info "Recovery validation completed. No issues found for ${params[TILES]} tiles."
    else
        # Partial metadata — some tiles have data, some don't. This is a real inconsistency.
        issues_found=$tiles_missing_metadata
        log_error "Recovery validation completed with $issues_found issue(s). Some tiles have data while others don't."
        log_warn "Suggested action: Re-run with --cr to clean up and start fresh, or re-run Discovery to recreate missing tiles."
    fi

    return $issues_found
}

[[ $# -eq 0 ]] && Usage_Exit

while (( "$#" )); do
    case "$1" in
        --state) params[STATE]="$2"; shift 2 ;;
        --tiles|-t) params[TILES]="$2"; shift 2 ;;
        --landing-zone|-lz) params[S3_LANDING_ZONE]="$2"; shift 2 ;;
        --src-keyspace|-sk) params[SOURCE_KS]="$2"; shift 2 ;;
        --src-table|-st) params[SOURCE_TBL]="$2"; shift 2 ;;
        --region|-sr) params[AWS_REGION]="$2"; shift 2 ;;
        --total-dpu|-tdpu) params[TOTAL_DPU]="$2"; shift 2 ;;
        --) shift; break ;;
        -*|--*=) log_error "Unknown option: $1"; Usage_Exit ;;
        *) PARAMS="$PARAMS $1"; shift ;;
    esac
done

[[ -n "$PARAMS" ]] && eval set -- "$PARAMS"

[[ ${params[STATE]} == recovery ]] && {
  Recovery
  exit $?
}
[[ ${params[STATE]} == get-tco ]] && {
  Get_TCO
  exit $?
}
